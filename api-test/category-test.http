@auth_token = <SET_ME_AT_RUNTIME_tenten>

# 수정할 본인 소유의 첫 번째 카테고리 ID (DB에서 본인 소유 카테고리 UUID 확인 후 입력)
@category_id = 3ea658f9-b600-4a7b-b8bd-7e5c8722ed33

# 수정할 본인 소유의 두 번째 카테고리 ID (중복 이름 검증 테스트용)
@another_category_id = 5f3ca5c1-cf89-4f05-b384-55e03b887c36

@base_url = http://localhost:8080
# @base_url = https://calbak.o-r.kr

### 1. 기존 카테고리 수정 (성공)
PATCH {{base_url}}/api/categories/{{category_id}}
Content-Type: application/json
Cookie: access_token={{auth_token}}; XSRF-TOKEN={{csrf_token}}
X-XSRF-TOKEN: {{csrf_token}}

{
    "name": "동아리",
    "colorCode": "#FF5733"
}


### 2. 똑같은 이름으로 다른 카테고리 수정 시도 (중복 방지 에러 발생해야 함)
PATCH {{base_url}}/api/categories/{{another_category_id}}
Content-Type: application/json
Cookie: access_token={{auth_token}}; XSRF-TOKEN={{csrf_token}}
X-XSRF-TOKEN: {{csrf_token}}

{
    "name": "동아리",
    "colorCode": "#000000"
}
